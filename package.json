{
  "name": "atlas-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:mobile": "npm run start --workspace @atlas/mobile",
    "build": "vite build",
    "build:web": "vite build",
    "preview": "vite preview",
    "mobile:start": "npm run start --workspace @atlas/mobile",
    "mobile:android": "npm run android --workspace @atlas/mobile",
    "mobile:ios": "npm run ios --workspace @atlas/mobile",
    "mobile:web": "npm run web --workspace @atlas/mobile",
    "start": "serve -s dist -l $PORT",
    "heroku-postbuild": "npm run build",
    "data:partner-capabilities": "node scripts/build-partner-capabilities.js",
    "test:route-ranking": "node scripts/test-route-ranking.js"
  },
  "dependencies": {
    "@atlas/shared": "*",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-tabs": "^1.0.4",
    "@react-google-maps/api": "^2.20.7",
    "@supabase/supabase-js": "^2.104.0",
    "@visx/group": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "d3-scale": "^4.0.2",
    "firebase": "^10.13.0",
    "gsap": "^3.13.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.395.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.0",
    "serve": "^14.2.6",
    "tailwind-merge": "^2.3.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  }
}
