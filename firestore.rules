rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Utility helpers **/
    function isSignedIn() {
      return request.auth != null;
    }

    function isCurrentUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasRole(role) {
      return isSignedIn() && request.auth.token.role == role;
    }

    function hasAnyRole() {
      return hasRole('peerNavigator') ||
        hasRole('stationOperator') ||
        hasRole('regionalDirector') ||
        hasRole('governanceAdmin') ||
        hasRole('readOnlyFunder');
    }

    function canWriteOperationalData() {
      return hasRole('peerNavigator') || hasRole('stationOperator') || hasRole('regionalDirector');
    }

    function isGovernanceAdmin() {
      return hasRole('governanceAdmin');
    }

    /**
     * User profiles
     * Each authenticated user can read and update their own profile document.
     */
    match /artifacts/{appId}/users/{userId}/profile/main {
      allow read, write: if isCurrentUser(userId);
    }

    /** Canonical ATLAS 2026 operational data **/
    match /artifacts/{appId}/atlas2026/participants/{participantId} {
      allow read: if hasAnyRole();
      allow create, update: if canWriteOperationalData();
      allow delete: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/routes/{routeId} {
      allow read: if hasAnyRole();
      allow create, update: if canWriteOperationalData();
      allow delete: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/routeSteps/{stepId} {
      allow read: if hasAnyRole();
      allow create, update: if canWriteOperationalData();
      allow delete: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/memoryEvents/{eventId} {
      allow read: if hasAnyRole();
      allow create: if canWriteOperationalData();
      allow update, delete: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/capacityTopology/{nodeId} {
      allow read: if hasAnyRole();
      allow create, update, delete: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/ontology/{document=**} {
      allow read: if hasAnyRole();
      allow write: if isGovernanceAdmin();
    }

    match /artifacts/{appId}/atlas2026/ontologyAudit/{auditId} {
      allow read: if hasAnyRole();
      allow create: if isGovernanceAdmin();
      allow update, delete: if false;
    }

    match /artifacts/{appId}/atlas2026/renewalRoles/{participantId} {
      allow read: if hasAnyRole();
      allow create, update: if canWriteOperationalData() || isGovernanceAdmin();
      allow delete: if isGovernanceAdmin();
    }

    /**
     * Legacy collections are no longer writable in the 2026 clean-break posture.
     * Reads are kept temporarily for audit and migration validation only.
     */
    match /artifacts/{appId}/public/data/{document=**} {
      allow read: if hasAnyRole();
      allow write: if false;
    }

    match /artifacts/{appId}/participants/{participantId}/{document=**} {
      allow read: if hasAnyRole();
      allow write: if false;
    }

    match /artifacts/{appId}/partners/{partnerId}/{document=**} {
      allow read: if hasAnyRole();
      allow write: if false;
    }

    match /artifacts/{appId}/countyCommons/{countyId}/{document=**} {
      allow read: if hasAnyRole();
      allow write: if false;
    }
  }
}

